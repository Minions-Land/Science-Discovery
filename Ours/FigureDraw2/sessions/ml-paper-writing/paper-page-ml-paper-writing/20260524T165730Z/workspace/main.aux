\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Chinchilla-style scaling law: validation loss vs.\ model size across 80 runs. Each point is one model; the orange line is an OLS fit ($\hat  {y} = -0.0449\,x + 0.6209$, $R^{2}=0.877$). The starred red point (\textbf  {RetroDiff}) is the closest data point to the target coordinates $(\log _{10}\text  {params}=9.449,\ \text  {loss}=0.2096)$.}}{3}{figure.4}\protected@file@percent }
\newlabel{fig:scaling}{{4}{3}{Chinchilla-style scaling law: validation loss vs.\ model size across 80 runs. Each point is one model; the orange line is an OLS fit ($\hat {y} = -0.0449\,x + 0.6209$, $R^{2}=0.877$). The starred red point (\textbf {\methodname }) is the closest data point to the target coordinates $(\log _{10}\text {params}=9.449,\ \text {loss}=0.2096)$}{figure.4}{}}
