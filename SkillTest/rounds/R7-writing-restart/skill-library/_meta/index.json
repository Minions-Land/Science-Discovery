    "rule_count": 4,
    "path": "skills/abbreviation-discipline/SKILL.md"
  },
  {
    "name": "abstract-discipline",
    "description": "撰写或润色论文 Abstract 与 Conclusion 时，确保单段、无引用、无具体数字、无数据集名。CNS 严格执行；会议论文推荐执行。",
    "scope": {
      "section": [
        "abstract",
        "conclusion"
      ],
      "paper_type": [
        "CNS",
        "conference"
      ]
    },
    "triggers": [
      "写 abstract",
      "polish abstract",
      "润色摘要",
      "draft_section in [abstract, conclusion]"
    ],
    "rule_count": 4,
    "path": "skills/abstract-discipline/SKILL.md"
  },
  {
    "name": "citation-zero-hallucination",
    "description": "引用必须真实：不编造 BibTeX、不把作者记忆中的\"~12%\"当成已验证数字、不凭空加引用。",
    "scope": {
      "section": [
        "global"
      ],
      "paper_type": [
        "CNS",
        "conference"
      ]
    },
    "triggers": [
      "citation",
      "引用",
      "bib",
      "task in [draft, polish]",
      {
        "contains_pattern": "\\[VERIFY\\]|~\\d+%|approximately \\d+"
      }
    ],
    "rule_count": 5,
    "path": "skills/citation-zero-hallucination/SKILL.md"
  },
